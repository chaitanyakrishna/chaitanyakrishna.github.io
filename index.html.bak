                        </p>
                    </div>
                </div>

                <!-- EiQ Networks -->
                <div class="col-lg-6 col-md-6">
                    <div class="experience-card">
                        <span class="exp-duration">February 2016 – May 2017</span>
                        <h5 class="exp-title">Security Analyst</h5>
                        <p class="exp-company">EiQ Networks</p>
                        <p class="exp-description">
