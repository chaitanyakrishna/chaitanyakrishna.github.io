                <!-- Deloitte India -->
                <div class="col-lg-6 col-md-6">
                    <div class="experience-card">
                        <span class="exp-duration">July 2015 – January 2016</span>
                        <h5 class="exp-title">Enterprise Risk Services Consultant</h5>
